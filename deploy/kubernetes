# 智知因 - Kubernetes部署配置
apiVersion: apps/v1
kind: Deployment
metadata:
  name: zhiyin-api
  labels:
    app: zhiyin-api
spec:
  replicas: 2
  selector:
    matchLabels:
      app: zhiyin-api
  template:
    metadata:
      labels:
        app: zhiyin-api
    spec:
      containers:
      - name: api
        image: ghcr.io/your-repo/zhiyin/api:latest
        ports:
        - containerPort: 8000
        env:
        - name: DEEPSEEK_API_KEY
          valueFrom:
            secretKeyRef:
              name: zhiyin-secrets
              key: deepseek-api-key
        - name: DATABASE_URL
          value: "sqlite:///app/data/zhiyin.db"
        resources:
          requests:
            memory: "512Mi"
            cpu: "250m"
          limits:
            memory: "1Gi"
            cpu: "500m"
        livenessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 30
          periodSeconds: 10
        readinessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 5
          periodSeconds: 5
        volumeMounts:
        - name: data
          mountPath: /app/data
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: zhiyin-data
---
apiVersion: v1
kind: Service
metadata:
  name: zhiyin-api-service
spec:
  selector:
    app: zhiyin-api
  ports:
  - protocol: TCP
    port: 8000
    targetPort: 8000
  type: ClusterIP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: zhiyin-frontend
  labels:
    app: zhiyin-frontend
spec:
  replicas: 2
  selector:
    matchLabels:
      app: zhiyin-frontend
  template:
    metadata:
      labels:
        app: zhiyin-frontend
    spec:
      containers:
      - name: frontend
        image: ghcr.io/your-repo/zhiyin/frontend:latest
        ports:
        - containerPort: 8501
        env:
        - name: API_BASE
          value: "http://zhiyin-api-service:8000"
        resources:
          requests:
            memory: "256Mi"
            cpu: "100m"
          limits:
            memory: "512Mi"
            cpu: "200m"
---
apiVersion: v1
kind: Service
metadata:
  name: zhiyin-frontend-service
spec:
  selector:
    app: zhiyin-frontend
  ports:
  - protocol: TCP
    port: 8501
    targetPort: 8501
  type: LoadBalancer
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: zhiyin-data
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 10Gi
---
apiVersion: v1
kind: Secret
metadata:
  name: zhiyin-secrets
type: Opaque
stringData:
  deepseek-api-key: "YOUR_API_KEY_HERE"
